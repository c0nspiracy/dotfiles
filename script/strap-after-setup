#!/bin/bash

set -e

# Install Homebrew packages
brew bundle --file="$HOME/.dotfiles/Brewfile"

# Mac OS comes with zsh, so move the existing zshrc if it exists
if [ -e "$HOME/.zshrc" ] && [ ! -L "$HOME/.zshrc" ]; then
	echo ".zshrc exists and is not a symlink, moving it to .zshrc-pre-stow"
	mv "$HOME/.zshrc" "$HOME/.zshrc-pre-stow"
fi

stow_directory() {
	stow --verbose --dotfiles -d "$HOME/.dotfiles" -t "$HOME" $1
}

stow_directory "atuin"
stow_directory "bat"
stow_directory "bin"
stow_directory "brew-aliases"
stow_directory "ghostty"
stow_directory "glow"
stow_directory "irb"
stow_directory "mise"
stow_directory "nvim"
stow_directory "starship"
stow_directory "tmux"
stow_directory "zsh"

# Wire up the repo's tracked hooks directory (idempotent)
git -C "$HOME/.dotfiles" config --local core.hooksPath hooks

mise install
